{
  "name": "jed",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run start:dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build:web": "cd apps/web && npm run build",
    "build:api": "cd apps/api && npm run build",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:push": "cd packages/database && npx prisma db push",
    "db:seed": "cd packages/database && npx ts-node src/seed.ts",
    "install:all": "npm install && cd packages/database && npm install && cd ../../packages/shared && npm install && cd ../../apps/api && npm install && cd ../../apps/web && npm install",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3"
  }
}
